  [1m[36mCharacter Create (1.5ms)[0m  [1m[32mINSERT INTO "characters" ("backstory", "biography", "character_role_id", "created_at", "franchise_id", "history", "name", "photo_url", "plot_role", "status", "updated_at") VALUES ('Был оставлен отцом на попечение учителя после смерти матери. Рос в одиночестве и чувстве ненужности.', 'Третье Дитя, пилот Евангелиона-01.', 1, '2026-02-26 14:01:22.218755', 1, 'Прибывает в Токио-3 по зову отца, пилотирует Еву и проходит через череду психологических кризисов в поисках признания.', 'Синдзи Икари', NULL, 'Главный герой, на чьи плечи ложится груз ответственности за судьбу мира, к которой он не готов.', 'Жив', '2026-02-26 14:01:22.218755') RETURNING "id" /*application='AniguidePro'*/[0m
