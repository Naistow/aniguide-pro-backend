  [1m[36mCharacter Create (1.3ms)[0m  [1m[32mINSERT INTO "characters" ("backstory", "biography", "character_role_id", "created_at", "franchise_id", "history", "name", "photo_url", "plot_role", "status", "updated_at") VALUES ('Вундеркинд из Германии, ставшая свидетелем безумия и смерти матери в раннем возрасте.', 'Второе Дитя, пилот Евангелиона-02.', 1, '2026-02-26 14:01:22.228000', 1, 'Переезжает в Японию, борется за статус лучшего пилота, но ломается после ментальной атаки Ангела.', 'Аска Лэнгли Сорью', NULL, 'Высокомерный и талантливый пилот, скрывающий за маской превосходства глубокие травмы.', 'Жив', '2026-02-26 14:01:22.228000') RETURNING "id" /*application='AniguidePro'*/[0m
