  [1m[36mCharacter Create (1.3ms)[0m  [1m[32mINSERT INTO "characters" ("backstory", "biography", "character_role_id", "created_at", "franchise_id", "history", "name", "photo_url", "plot_role", "status", "updated_at") VALUES ('Искусственно созданный клон, в чьем теле заключена душа Лилит.', 'Первое Дитя, пилот Евангелиона-00.', 1, '2026-02-26 14:01:22.223347', 1, 'Жертвует собой ради спасения Синдзи, после чего её место занимает следующий клон с частичными воспоминаниями.', 'Рей Аянами', NULL, 'Загадочный пилот, чья личность тесно связана с тайнами проекта Комплементации.', 'Неизвестно', '2026-02-26 14:01:22.223347') RETURNING "id" /*application='AniguidePro'*/[0m
