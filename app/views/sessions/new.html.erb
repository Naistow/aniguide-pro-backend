<style>
  /* Стили такие же, как в регистрации */
  body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: #1e1e2f; color: #fff; margin: 0; }
  .auth-container { max-width: 400px; margin: 80px auto; background: #2a2a3b; padding: 30px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.4); border-top: 5px solid #2ecc71; }
  .auth-container h2 { text-align: center; margin-top: 0; color: #2ecc71; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; margin-bottom: 8px; color: #bdc3c7; font-size: 14px; }
  .form-group input { width: 100%; padding: 10px; box-sizing: border-box; border-radius: 6px; border: 1px solid #444; background: #1e1e2f; color: white; }
  .btn-submit { width: 100%; padding: 12px; background: #2ecc71; color: white; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; transition: background 0.2s; }
  .btn-submit:hover { background: #27ae60; }
  .alert { color: #e74c3c; text-align: center; margin-bottom: 15px; font-weight: bold; }
  .back-link { display: block; text-align: center; margin-top: 15px; color: #aaa; text-decoration: none; font-size: 14px; }
</style>

<div class="auth-container">
  <h2>Вход в AniGuide</h2>

  <% if flash[:alert] %>
    <div class="alert"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: '/login', local: true do |f| %>
    <div class="form-group">
      <%= f.label :email, "Ваш Email" %>
      <%= f.email_field :email, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Пароль" %>
      <%= f.password_field :password, required: true %>
    </div>

    <%= f.submit "Войти", class: "btn-submit" %>
  <% end %>
  
  <a href="/signup" class="back-link">Нет аккаунта? Зарегистрироваться</a>
  <a href="/" class="back-link">На главную</a>
</div>