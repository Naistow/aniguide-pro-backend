<style>
  .form-container { max-width: 600px; margin: 50px auto; background: #2a2a3b; padding: 40px; border-radius: 15px; border-top: 5px solid #f1c40f; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  .form-group { margin-bottom: 25px; }
  .form-group label { display: block; margin-bottom: 10px; color: #bdc3c7; font-weight: bold; font-size: 14px; }
  .form-group input, .form-group select { 
    width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #444; background: #1e1e2f; color: white; font-size: 16px; box-sizing: border-box;
  }
  .btn-save { width: 100%; padding: 15px; background: #f1c40f; color: #1a1a24; border: none; border-radius: 8px; font-size: 18px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
  .btn-save:hover { background: #d4ac0d; }
  .back-link { display: block; text-align: center; margin-top: 20px; color: #888; text-decoration: none; font-size: 14px; }
</style>

<div class="form-container">
  <h1 style="margin-top: 0; color: #f1c40f;">Новая часть гайда</h1>
  <p style="color: #888; margin-bottom: 30px;">Добавление аниме в порядок просмотра: <%= @franchise&.name %></p>

  <%= form_with model: @work, url: '/admin/works', local: true do |f| %>
    <div class="form-group">
      <%= f.label :title, "Название аниме" %>
      <%= f.text_field :title, placeholder: "Например: Fate/Stay Night", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :franchise_id, "Франшиза" %>
      <%= f.collection_select :franchise_id, Franchise.all, :id, :name, { selected: params[:franchise_id] } %>
    </div>

    <div class="form-group" style="display: flex; gap: 20px;">
      <div style="flex: 1;">
        <%= f.label :release_year, "Год выпуска" %>
        <%= f.number_field :release_year, value: Time.now.year %>
      </div>
      <div style="flex: 1;">
        <%= f.label :media_type_id, "Тип медиа" %>
        <%= f.collection_select :media_type_id, MediaType.all, :id, :name %>
      </div>
    </div>

    <p style="font-size: 12px; color: #888; background: #1e1e2f; padding: 10px; border-radius: 5px; border: 1px dashed #444;">
      ℹ️ После сохранения аниме будет автоматически добавлено в конец текущего списка порядка просмотра.
    </p>

    <%= f.submit "Добавить в порядок просмотра", class: "btn-save" %>
  <% end %>

  <a href="<%= @franchise ? guide_path(@franchise) : root_path %>" class="back-link">← Отмена</a>
</div>