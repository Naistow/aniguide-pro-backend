<div style="max-width: 800px; margin: 50px auto; padding: 40px;" class="theme-card">
  <h1 class="theme-title" style="margin-top: 0;">Добавление серии</h1>
  <p style="color: #888; margin-bottom: 30px;">Тайтл: <strong><%= @work.title %></strong></p>

  <%= form_with model: @episode, url: '/admin/episodes', local: true do |f| %>
    <%= f.hidden_field :work_id, value: @work.id %>

    <div style="display: grid; grid-template-columns: 100px 1fr; gap: 20px; margin-bottom: 20px;">
      <div>
        <%= f.label :episode_number, "Номер", style: "display:block; margin-bottom:5px; color:#888;" %>
        <%= f.number_field :episode_number, required: true, style: "width:100%; padding:10px; background:rgba(0,0,0,0.5); border:1px solid #444; color:white; border-radius:5px;" %>
      </div>
      <div>
        <%= f.label :title, "Название серии", style: "display:block; margin-bottom:5px; color:#888;" %>
        <%= f.text_field :title, required: true, style: "width:100%; padding:10px; background:rgba(0,0,0,0.5); border:1px solid #444; color:white; border-radius:5px;" %>
      </div>
    </div>

    <div style="margin-bottom: 25px;">
      <%= f.label :description, "Сюжет (Синопсис)", style: "display:block; margin-bottom:5px; color:#888;" %>
      <%= f.text_area :description, style: "width:100%; height:150px; padding:10px; background:rgba(0,0,0,0.5); border:1px solid #444; color:white; border-radius:5px;" %>
    </div>

    <div style="margin-bottom: 30px; background: rgba(0,0,0,0.2); padding: 20px; border-radius: 8px;">
      <h3 style="margin: 0 0 15px 0; color: inherit;">Персонажи в серии:</h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
        <%= f.collection_check_boxes :character_ids, @available_characters, :id, :name do |b| %>
          <div style="display: flex; align-items: center; gap: 8px;">
            <%= b.check_box %>
            <%= b.label style: "color: white; font-size: 14px; cursor: pointer;" %>
          </div>
        <% end %>
      </div>
    </div>

    <%= f.submit "Сохранить серию", class: "theme-btn", style: "width:100%; font-size: 16px;" %>
  <% end %>

  <a href="<%= work_profile_path(@work) %>" style="display:block; text-align:center; margin-top:20px; color:#888; text-decoration:none;">← Отмена</a>
</div>