<style>
  .form-container { max-width: 600px; margin: 50px auto; background: #2a2a3b; padding: 40px; border-radius: 15px; border-top: 5px solid #2ecc71; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  .form-group { margin-bottom: 25px; }
  .form-group label { display: block; margin-bottom: 10px; color: #bdc3c7; font-weight: bold; font-size: 14px; }
  .form-group input, .form-group textarea, .form-group select { 
    width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #444; background: #1e1e2f; color: white; font-size: 16px; box-sizing: border-box;
  }
  .form-group textarea { height: 150px; resize: vertical; }
  .btn-save { width: 100%; padding: 15px; background: #2ecc71; color: white; border: none; border-radius: 8px; font-size: 18px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
  .btn-save:hover { background: #27ae60; }
  .back-link { display: block; text-align: center; margin-top: 20px; color: #888; text-decoration: none; font-size: 14px; }
</style>

<div class="form-container">
  <h1 style="margin-top: 0; color: #2ecc71;">Новый термин</h1>
  <p style="color: #888; margin-bottom: 30px;">Пополнение глоссария вселенной: <%= @franchise&.name %></p>

  <%= form_with model: @term, url: '/admin/glossary', local: true do |f| %>
    <div class="form-group">
      <%= f.label :term, "Термин или понятие" %>
      <%= f.text_field :term, placeholder: "Например: LCL или Командные заклинания", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :franchise_id, "Франшиза" %>
      <%= f.collection_select :franchise_id, Franchise.all, :id, :name, { selected: params[:franchise_id] } %>
    </div>

    <div class="form-group">
      <%= f.label :definition, "Определение (описание)" %>
      <%= f.text_area :definition, placeholder: "Подробно объясните значение термина...", required: true %>
    </div>

    <%= f.submit "Добавить в глоссарий", class: "btn-save" %>
  <% end %>

  <a href="<%= @franchise ? franchise_glossary_path(@franchise) : root_path %>" class="back-link">← Отмена</a>
</div>