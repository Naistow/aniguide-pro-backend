<style>
  /* Стили формы как при регистрации */
  body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: #1e1e2f; color: #fff; margin: 0; }
  .form-container { max-width: 500px; margin: 80px auto; background: #2a2a3b; padding: 30px; border-radius: 12px; border-top: 5px solid #9b59b6; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; margin-bottom: 8px; color: #bdc3c7; }
  .form-group input, .form-group textarea { width: 100%; padding: 10px; box-sizing: border-box; border-radius: 6px; border: 1px solid #444; background: #1e1e2f; color: white; }
  .form-group textarea { resize: vertical; height: 100px; }
  .btn-submit { width: 100%; padding: 12px; background: #9b59b6; color: white; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; }
</style>

<div class="form-container">
  <h2 style="color: #9b59b6; margin-top: 0;">Новая Франшиза</h2>

  <%= form_with model: @franchise, url: '/admin/franchises', local: true do |f| %>
    <div class="form-group">
      <%= f.label :name, "Название (например: Dark Souls)" %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :theme, "CSS-тема (например: magic-theme, nerv-theme)" %>
      <%= f.text_field :theme %>
    </div>

    <div class="form-group">
      <%= f.label :description, "Краткое описание" %>
      <%= f.text_area :description %>
    </div>

    <%= f.submit "Добавить в базу", class: "btn-submit" %>
  <% end %>
  
  <div style="text-align: center; margin-top: 15px;">
    <a href="/admin" style="color: #aaa; text-decoration: none;">← Назад в панель</a>
  </div>
</div>