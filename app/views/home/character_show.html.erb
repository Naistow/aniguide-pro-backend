<style>
  .profile-grid { display: grid; grid-template-columns: 350px 1fr; gap: 40px; margin-top: 20px; }
  .portrait-img { width: 100%; height: 450px; object-fit: cover; display: block; }
  .section-header { font-size: 20px; font-weight: bold; margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 10px; }
</style>

<div style="max-width: 1200px; margin: 40px auto; padding: 20px;">
  <a href="<%= franchise_characters_path(@character.franchise) %>" style="text-decoration: none; font-size: 14px;">← Вернуться в архив</a>

  <div class="profile-grid">
    <div>
      <div class="theme-card" style="padding: 0; overflow: hidden; position: sticky; top: 100px;">
        <% if @character.portrait.attached? %>
          <%= image_tag @character.portrait, class: "portrait-img" %>
        <% else %>
          <div style="height: 450px; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; font-size: 80px;">👤</div>
        <% end %>

        <div style="padding: 25px; text-align: center;">
          <h1 class="theme-title" style="margin: 0 0 10px 0; font-size: 28px;"><%= @character.name %></h1>
          
          <div class="theme-badge"><%= @character.character_role.name %></div>

          <% if @character.status.present? %>
            <div style="margin-top: 10px; font-weight: bold; letter-spacing: 1px;">
              STATUS: <%= @character.status %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div>
      <div class="theme-card" style="margin-bottom: 25px;">
        <div class="section-header" style="color: inherit;">Роль в сюжете</div>
        <div style="line-height: 1.8; opacity: 0.9;"><%= @character.plot_role.presence || "Информация засекречена." %></div>
      </div>

      <div class="theme-card" style="margin-bottom: 25px;">
        <div class="section-header" style="color: inherit;">Личное дело / Предыстория</div>
        <div style="line-height: 1.8; opacity: 0.9; white-space: pre-wrap;"><%= @character.backstory.presence || @character.history.presence || "Архивы пусты." %></div>
      </div>

      <div class="theme-card">
        <div class="section-header" style="color: inherit;">Зафиксированные участия (Эпизоды)</div>
        
        <% if @episodes.any? %>
          <% # Группируем эпизоды по тайтлам (Works) %>
          <% @episodes.group_by(&:work).each do |work, episodes| %>
            <div style="margin-bottom: 25px;">
              <h3 style="margin: 0 0 10px 0; font-size: 16px; opacity: 0.9;"><%= work.title %></h3>
              
              <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <% episodes.each do |ep| %>
                  <a href="<%= work_profile_path(work) %>#episode-<%= ep.id %>" 
                     class="theme-btn" 
                     style="padding: 8px 12px; font-size: 12px;"
                     title="<%= ep.title %>">
                    ЭП. <%= ep.episode_number %>
                  </a>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p style="opacity: 0.7; font-style: italic;">Участий в конкретных сериях не найдено.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>