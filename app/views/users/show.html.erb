<style>
  body { margin: 0; background-color: #020617; color: #f8fafc; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
  .profile-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: radial-gradient(circle at 50% 0%, #1e293b 0%, #020617 70%); z-index: -2; }
  .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
  
  /* Шапка профиля теперь гибкая */
  .profile-header { display: flex; flex-direction: column; gap: 20px; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(10px); padding: 30px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 30px; align-items: center; text-align: center; }
  
  @media (min-width: 769px) {
    .profile-header { flex-direction: row; justify-content: space-between; text-align: left; align-items: center; padding: 40px; }
  }

  .header-left { display: flex; flex-direction: column; align-items: center; gap: 20px; }
  @media (min-width: 769px) {
    .header-left { flex-direction: row; }
  }

  .avatar-circle { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: bold; color: white; border: 4px solid #0f172a; flex-shrink: 0; }
  .user-info h1 { margin: 0 0 5px 0; font-size: 28px; }

  .btn-logout { width: 100%; display: inline-flex; align-items: center; justify-content: center; background: transparent; border: 1px solid #ef4444; color: #ef4444; padding: 12px; border-radius: 10px; font-weight: bold; text-decoration: none; }
  @media (min-width: 769px) {
    .btn-logout { width: auto; padding: 12px 24px; }
  }

  .section-title { font-size: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-top: 30px; }
  .favorites-scroll { display: flex; gap: 15px; overflow-x: auto; padding-bottom: 15px; -webkit-overflow-scrolling: touch; }
  .fav-card { flex: 0 0 130px; }
</style>

<div class="profile-bg"></div>

<div class="container">
  <div class="profile-header">
    <div class="header-left">
      <div class="avatar-circle"><%= current_user.name.first.upcase rescue 'U' %></div>
      <div class="user-info">
        <h1><%= current_user.name rescue 'Пользователь' %></h1>
        <div class="user-badge <%= 'admin' if current_user.try(:admin?) %>">
          <%= current_user.try(:admin?) ? 'Администратор' : 'Пользователь' %>
        </div>
        <p style="color: #64748b; margin-top: 10px;"><%= current_user.email rescue '' %></p>
      </div>
    </div>
    
    <div>
      <%= button_to "Выйти из аккаунта", logout_path, method: :delete, class: "btn-logout" %>
    </div>
  </div>

  <div class="section-title">Лайкнутые тайтлы (Аниме)</div>
  <div class="favorites-scroll">
    <% if current_user.favorite_works.any? %>
      <% current_user.favorite_works.each do |work| %>
        <a href="<%= work_path(work) %>" class="fav-card">
          <div class="fav-img" style="<%= "background-image: url('#{work.image_url}');" if work.image_url.present? %>"></div>
          <div class="fav-type">Аниме</div>
          <div class="fav-name"><%= work.title %></div>
        </a>
      <% end %>
    <% else %>
      <div style="color: #64748b; font-style: italic;">Вы еще не добавили ни одного тайтла в избранное.</div>
    <% end %>
  </div>

  <div class="section-title">Лайкнутые персонажи</div>
  <div class="favorites-scroll">
    <% if current_user.favorite_characters.any? %>
      <% current_user.favorite_characters.each do |char| %>
        <% portrait_url = char.respond_to?(:portrait) && char.portrait.attached? ? url_for(char.portrait) : (char.try(:image_url) || "") %>
        <a href="<%= character_profile_path(char) %>" class="fav-card">
          <div class="fav-img" style="<%= "background-image: url('#{portrait_url}');" if portrait_url.present? %>"></div>
          <div class="fav-type">Персонаж</div>
          <div class="fav-name"><%= char.name %></div>
        </a>
      <% end %>
    <% else %>
      <div style="color: #64748b; font-style: italic;">Вы еще не добавили ни одного персонажа в избранное.</div>
    <% end %>
  </div>
</div>