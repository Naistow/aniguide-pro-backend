<style>
  body { margin: 0; background-color: #020617; color: #f8fafc; font-family: 'Segoe UI', sans-serif; }
  .profile-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: radial-gradient(circle at 50% 0%, #1e293b 0%, #020617 70%); z-index: -2; }
  .container { max-width: 1000px; margin: 0 auto; padding: 60px 20px; }
  
  .profile-header { display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(10px); padding: 40px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 20px 40px rgba(0,0,0,0.4); margin-bottom: 40px; }
  .header-left { display: flex; align-items: center; gap: 30px; }
  .avatar-circle { width: 120px; height: 120px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: bold; color: white; box-shadow: 0 10px 20px rgba(59, 130, 246, 0.4); border: 4px solid #0f172a; }
  .user-info h1 { margin: 0 0 10px 0; font-size: 36px; }
  .user-badge { display: inline-block; background: rgba(59, 130, 246, 0.2); color: #3b82f6; padding: 6px 12px; border-radius: 8px; font-size: 14px; font-weight: bold; border: 1px solid rgba(59, 130, 246, 0.4); }
  .user-badge.admin { background: rgba(239, 68, 68, 0.2); color: #ef4444; border-color: rgba(239, 68, 68, 0.4); }

  .btn-logout { display: inline-flex; align-items: center; justify-content: center; background: transparent; border: 1px solid #ef4444; color: #ef4444; padding: 12px 24px; border-radius: 10px; font-weight: bold; text-decoration: none; transition: all 0.2s; cursor: pointer; }
  .btn-logout:hover { background: #ef4444; color: white; }

  .section-title { font-size: 24px; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px; margin-bottom: 25px; margin-top: 50px; }
  .favorites-scroll { display: flex; gap: 20px; overflow-x: auto; padding-bottom: 20px; }
  .favorites-scroll::-webkit-scrollbar { height: 8px; }
  .favorites-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); border-radius: 4px; }
  .favorites-scroll::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 4px; }

  .fav-card { flex: 0 0 150px; text-decoration: none; color: white; display: flex; flex-direction: column; align-items: center; transition: transform 0.2s; }
  .fav-card:hover { transform: translateY(-5px); }
  .fav-img { width: 100%; aspect-ratio: 3/4; border-radius: 12px; background-color: #1e293b; background-size: cover; background-position: center; margin-bottom: 10px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
  .fav-name { font-size: 14px; font-weight: bold; text-align: center; line-height: 1.2; }
  .fav-type { font-size: 11px; color: #3b82f6; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;}
</style>

<div class="profile-bg"></div>

<div class="container">
  <div class="profile-header">
    <div class="header-left">
      <div class="avatar-circle"><%= current_user.name.first.upcase rescue 'U' %></div>
      <div class="user-info">
        <h1><%= current_user.name rescue 'Пользователь' %></h1>
        <div class="user-badge <%= 'admin' if current_user.try(:admin?) %>">
          <%= current_user.try(:admin?) ? 'Администратор' : 'Пользователь' %>
        </div>
        <p style="color: #64748b; margin-top: 10px;"><%= current_user.email rescue '' %></p>
      </div>
    </div>
    
    <div>
      <%= button_to "Выйти из аккаунта", logout_path, method: :delete, class: "btn-logout" %>
    </div>
  </div>

  <div class="section-title">Лайкнутые тайтлы (Аниме)</div>
  <div class="favorites-scroll">
    <% if current_user.favorite_works.any? %>
      <% current_user.favorite_works.each do |work| %>
        <a href="<%= work_path(work) %>" class="fav-card">
          <div class="fav-img" style="<%= "background-image: url('#{work.image_url}');" if work.image_url.present? %>"></div>
          <div class="fav-type">Аниме</div>
          <div class="fav-name"><%= work.title %></div>
        </a>
      <% end %>
    <% else %>
      <div style="color: #64748b; font-style: italic;">Вы еще не добавили ни одного тайтла в избранное.</div>
    <% end %>
  </div>

  <div class="section-title">Лайкнутые персонажи</div>
  <div class="favorites-scroll">
    <% if current_user.favorite_characters.any? %>
      <% current_user.favorite_characters.each do |char| %>
        <% portrait_url = char.respond_to?(:portrait) && char.portrait.attached? ? url_for(char.portrait) : (char.try(:image_url) || "") %>
        <a href="<%= character_profile_path(char) %>" class="fav-card">
          <div class="fav-img" style="<%= "background-image: url('#{portrait_url}');" if portrait_url.present? %>"></div>
          <div class="fav-type">Персонаж</div>
          <div class="fav-name"><%= char.name %></div>
        </a>
      <% end %>
    <% else %>
      <div style="color: #64748b; font-style: italic;">Вы еще не добавили ни одного персонажа в избранное.</div>
    <% end %>
  </div>
</div>